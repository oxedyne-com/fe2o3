#!/usr/bin/env bash
# Tail the Steel dev log on deployhost.
#
# Usage:
#   scripts/steel_logs           # follow the structured log
#   scripts/steel_logs --raw     # follow the raw stdout log (tee target)
#   scripts/steel_logs --pane    # snapshot the tmux pane

set -euo pipefail

mode="structured"
for arg in "$@"; do
    case "$arg" in
        --raw)          mode="raw" ;;
        --pane)         mode="pane" ;;
        -h|--help)
            sed -n '2,9p' "$0"
            exit 0
            ;;
        *)
            echo "Unknown argument: $arg" >&2
            exit 2
            ;;
    esac
done

case "$mode" in
    structured)
        ssh operator@example.host 'tail -f ~/steel-dev/www/logs/steel-dev.log'
        ;;
    raw)
        ssh operator@example.host 'tail -f ~/steel-dev/steel.log'
        ;;
    pane)
        ssh operator@example.host 'tmux capture-pane -t steel-dev -p'
        ;;
esac
