#!/usr/bin/env bash
# Run the smoke-test matrix against the Steel dev instance on deployhost.
#
# Tests:
#   1. SNI dispatch for test.example.com
#   2. SNI dispatch for test-app.example.com
#   3. Exact-match redirect (/example)
#   4. Prefix-match redirect (/example/foo)
#   5. Host header mismatch returns 421
#
# Usage: scripts/steel_probe [--host <name>]
#
# By default probes via ssh into deployhost (so it works even when the server
# isn't exposed outside of deployhost). Use --local-ip IP to probe from this
# machine directly once the port is opened.

set -euo pipefail

via="deployhost"
ip="127.0.0.1"

while [ $# -gt 0 ]; do
    case "$1" in
        --local-ip)
            via="local"
            ip="$2"
            shift 2
            ;;
        -h|--help)
            sed -n '2,18p' "$0"
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            exit 2
            ;;
    esac
done

run() {
    if [ "$via" = "deployhost" ]; then
        ssh operator@example.host "$*"
    else
        eval "$*"
    fi
}

rule() {
    echo
    echo "=== $1 ==="
}

rule "1. test.example.com -> test-example webroot"
run "curl -sk --resolve test.example.com:8443:$ip https://test.example.com:8443/ -w '\nHTTP %{http_code}\n'" \
    | grep -E "HTTP|<h1>" || echo "(no match)"

rule "2. test-app.example.com -> test-example webroot"
run "curl -sk --resolve test-app.example.com:8443:$ip https://test-app.example.com:8443/ -w '\nHTTP %{http_code}\n'" \
    | grep -E "HTTP|<h1>" || echo "(no match)"

rule "3. test.example.com/example (exact redirect)"
run "curl -sk -I --resolve test.example.com:8443:$ip https://test.example.com:8443/example" \
    | head -5

rule "4. test.example.com/example/foo (prefix redirect)"
run "curl -sk -I --resolve test.example.com:8443:$ip https://test.example.com:8443/example/foo" \
    | head -5

rule "5. SNI/Host mismatch -> 421"
run "curl -sk -I --resolve test.example.com:8443:$ip https://test.example.com:8443/ -H 'Host: other.example.com'" \
    | head -3
