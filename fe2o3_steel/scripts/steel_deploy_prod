#!/usr/bin/env bash
# Production deploy for Steel on deployhost.
#
# Build the release binary locally, rsync it into ~/steel-prod/ on deployhost,
# re-apply the CAP_NET_BIND_SERVICE capability (setcap is wiped by rsync
# because security.* xattrs are root-only), and restart the steel.service
# systemd unit. Finally probe the four live vhosts to confirm the new build
# is serving.
#
# Unlike `steel_deploy` (the tmux-based dev loop), this script targets the
# production deployment on port 443 with a real Let's Encrypt certificate.
#
# Usage: scripts/steel_deploy_prod [--no-build] [--no-restart]

set -euo pipefail

no_build=false
no_restart=false
for arg in "$@"; do
    case "$arg" in
        --no-build)     no_build=true ;;
        --no-restart)   no_restart=true ;;
        -h|--help)
            sed -n '2,15p' "$0"
            exit 0
            ;;
        *)
            echo "Unknown argument: $arg" >&2
            exit 2
            ;;
    esac
done

HERE="$(cd "$(dirname "$0")"/.. && pwd)"
WORKSPACE="$(cd "$HERE"/.. && pwd)"
REMOTE_USER=jason
REMOTE_HOST=deployhost
REMOTE_DIR=/home/jason/usr/steel-prod

if ! $no_build; then
    echo "[1/4] cargo build --release -p oxedyne_fe2o3_steel"
    (cd "$WORKSPACE" && cargo build --release -p oxedyne_fe2o3_steel)
fi

BIN="$WORKSPACE/target/release/steel"
if [ ! -x "$BIN" ]; then
    echo "no steel binary at $BIN -- did the build succeed?" >&2
    exit 1
fi

echo "[2/4] rsync $BIN -> $REMOTE_HOST:$REMOTE_DIR/steel"
rsync -a "$BIN" "$REMOTE_USER@$REMOTE_HOST:$REMOTE_DIR/steel"

if $no_restart; then
    echo "--no-restart set; binary deployed, service not restarted."
    exit 0
fi

echo "[3/4] re-apply capability and restart steel.service"
ssh "$REMOTE_USER@$REMOTE_HOST" bash -s <<'REMOTEEND'
set -euo pipefail
sudo setcap cap_net_bind_service=+ep ~/steel-prod/steel
sudo systemctl restart steel
# Give the DB bots and ACME state pump a moment to finish warming up.
for i in 1 2 3 4 5; do
    sleep 1
    if ss -ltn 2>/dev/null | grep -q ':443 '; then
        echo "bound on 443 (attempt $i)"
        break
    fi
done
sudo systemctl is-active steel
REMOTEEND

echo "[4/4] smoke-probing the four live vhosts"
ssh "$REMOTE_USER@$REMOTE_HOST" bash -s <<'REMOTEEND'
set -e
probe () {
    local name="$1" url="$2" want="$3"
    local code
    code=$(curl -s "$url" -o /dev/null -w "%{http_code}")
    if [ "$code" = "$want" ]; then
        echo "  OK    $name -> HTTP $code"
    else
        echo "  FAIL  $name -> HTTP $code (wanted $want)"
        return 1
    fi
}
probe "example.com"               https://example.com/                  200
probe "app.example.com"     https://app.example.com/        200
probe "www.example.com"           https://www.example.com/              301
probe "www.app.example.com" https://www.app.example.com/    301
REMOTEEND

echo
echo "deploy complete."
