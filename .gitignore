# Ignore files that do not have an extension (typically executable files)
*
!*/
!*.*

# Rust
/target/
#Cargo.lock # removed for reproducible app builds, e.g. fe2o3_steel
**/*.rs.bk

# SABER C static libraries (regenerated by fe2o3_crypto/build.rs)
fe2o3_crypto/src/c/lib*.a

# Ozone test artefacts (regenerated by test runs)
fe2o3_o3db_sync/test_db*/

# Logs
*.log

# Source code text file bundles
txtcat_*.txt

# Vim
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
*.bak
.commit_msg.txt

# OS specific
.DS_Store
.directory
Thumbs.db

# IDE
.idea/
.vscode/
*.iml

.srcat/

# The two Unicode bidi conformance suites are 15 MB between them. They are fetched on demand
# by fe2o3_text/tests/unicode.rs, at the UCD version the committed tables were generated from.
fe2o3_text/tests/unicode_data/BidiTest.txt
fe2o3_text/tests/unicode_data/BidiCharacterTest.txt
